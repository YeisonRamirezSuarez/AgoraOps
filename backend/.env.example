# Conexión Postgres (Supabase: Settings → Database → Connection string URI)
# Local:    postgresql://postgres:postgres@localhost:5432/agoraops
# Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.<proyecto>.supabase.co:5432/postgres
# Nota: caracteres especiales de la contraseña van percent-encoded (% → %25, , → %2C)
# Si la conexión directa falla (IPv6), usar la URI del "Session pooler".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agoraops

# JWT
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=12h

# Servidor
PORT=4000
CORS_ORIGIN=http://localhost:5173
