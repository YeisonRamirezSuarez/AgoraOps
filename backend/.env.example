# Conexión Postgres (Supabase: Settings → Database → Connection string URI)
# Local:    postgresql://postgres:postgres@localhost:5432/agoraops
# Nota: caracteres especiales de la contraseña van percent-encoded (% → %25, , → %2C)
#
# En Supabase serverless usa el "Transaction pooler" (puerto 6543) para
# DATABASE_URL: multiplexa conexiones cortas sobre pocas reales. Si la conexión
# directa db.<proyecto>.supabase.co falla (es solo IPv6), usa el host del pooler.
# DATABASE_URL=postgresql://postgres.<ref>:[PASSWORD]@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agoraops

# DATABASE_SESSION_URL — SOLO para el listener SSE (events.ts). LISTEN/NOTIFY no
# funciona bajo el transaction pooler (6543), así que necesita una conexión en
# "Session pooler" (puerto 5432). Si se omite, cae a DATABASE_URL (en Postgres
# local directo LISTEN funciona, no hace falta definirla).
# DATABASE_SESSION_URL=postgresql://postgres.<ref>:[PASSWORD]@<region>.pooler.supabase.com:5432/postgres

# Tamaño máximo del pool de conexiones para la base de datos (por defecto 10 en dev, 5 en prod)
DB_POOL_MAX=10

# SSL estricto contra Supabase (valida el certificado). Dejar sin definir o
# en false si el pooler no presenta un certificado verificable.
# DATABASE_SSL_STRICT=true
# CA de Supabase para la validación estricta (Settings → Database → SSL
# Configuration → Download certificate). Acepta el PEM en línea o una ruta.
# DATABASE_SSL_CA=./prod-ca-2021.crt

# JWT — OBLIGATORIO en producción (sin él el backend no arranca). Usa un valor
# largo y aleatorio, distinto por entorno.
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=12h

# Servidor
PORT=4000
CORS_ORIGIN=http://localhost:5173

# SMTP para los correos transaccionales: "recuperar contraseña" y "apertura de
# establecimiento" (bienvenida al administrador). Si se deja sin configurar, el
# backend NO envía correo: registra los datos en la consola (modo dev) para que
# el flujo siga siendo probable. Ejemplo con Gmail/SendGrid/Mailgun/etc.
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=587            # 465 si SMTP_SECURE=true
# SMTP_SECURE=false        # true => SSL (puerto 465); false => STARTTLS (587)
# SMTP_USER=usuario_smtp
# SMTP_PASS=clave_smtp
# MAIL_FROM=AgoraOps <no-reply@tudominio.com>
