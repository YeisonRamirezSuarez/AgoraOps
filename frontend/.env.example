# URL pública del backend AgoraOps en producción (proyecto Vercel del backend).
# Ej.: VITE_API_URL=https://agoraops-api.vercel.app
# OJO: NO debe apuntar a localhost. Debe ser el dominio donde está desplegada
# la API (backend/), y ese dominio debe permitir este frontend en CORS_ORIGIN.
# Reemplaza el valor de abajo por la URL real en tu archivo local .env.production o en el panel de Vercel.
VITE_API_URL=
